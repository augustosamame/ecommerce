<% content_for :head do %>
<% nofollow %>
<% noindex %>
<%= stylesheet_link_tag    'ecommerce/backoffice', media: 'all' %>
<%= csrf_meta_tag %>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
<link href="https://fonts.googleapis.com/css?family=Open+Sans" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.0/css/select2.min.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.0/js/select2.min.js"></script>

<!-- AQUI VAN LOS CSS Y JS SOLO DE BACKOFFICE -->

<% end %>

<!-- AQUI VA EL BODY SOLO DE BACKOFFICE -->

<!-- BEGIN HEADER -->

<%= render 'ecommerce/backoffice/header' %>

<!-- END HEADER -->

<!-- BEGIN CONTENT -->
  <div class="page-container row-fluid">

    <%= render "ecommerce/backoffice/sidebar" %>

    <!-- BEGIN PAGE CONTAINER-->
    <div class="page-content">

      <div class="content">

        <%= render 'ecommerce/application/flashes' %>
        <%= render 'ecommerce/application/spinner' %>

        <%= yield %>

      </div>
    </div>

  </div>
  <!-- END CONTENT -->
  <% # Javascript at the bottom for fast page loading %>
<%= javascript_include_tag 'ecommerce/backoffice' %>

<script type="text/javascript">
$(document).ready(function(){
  $('.show-spinner').click(function() {
      $('.spinner').show();
  });
});
</script>

<script>
//disable change number with scroll on all number fields
$(function(){
  $(':input[type=number]').on('mousewheel',function(e){ $(this).blur(); });
});
</script>

<script type="text/javascript">
$(document).ready(function(){

  /* Activating Best In Place */
  jQuery(".best_in_place").best_in_place();

  // set sidebar state
  if (getCookie('collapsed-sidebar') == 'true') {
    $('#layout-condensed-toggle').click();
  }

  // Backoffice header search — AJAX autocomplete. Replaces the prior approach
  // of inlining all users/orders/products as JSON in every page; that pushed
  // first-load over 30s. Each search now hits a `LIMIT 20` endpoint and the
  // results render after a small debounce.
  var BO_BASE = "/<%= Ecommerce.engine_alias_endpoint %>/backoffice";

  function ajaxSource(url, extraParams) {
    return function(request, response) {
      $.getJSON(url, $.extend({ term: request.term }, extraParams || {}), response);
    };
  }

  $(".search_users").autocomplete({
    minLength: 2,
    delay: 250,
    source: ajaxSource(BO_BASE + "/users/autocomplete"),
    select: function (e, ui) {
      window.location.href = BO_BASE + "/users/" + ui.item.id;
    }
  });
  $(".search_products").autocomplete({
    minLength: 2,
    delay: 250,
    source: ajaxSource(BO_BASE + "/products/autocomplete"),
    select: function (e, ui) {
      window.location.href = BO_BASE + "/products/" + ui.item.id;
    }
  });
  $(".search_category_products").autocomplete({
    minLength: 2,
    delay: 250,
    source: ajaxSource(BO_BASE + "/products/autocomplete", { with_categories: 1 }),
    select: function (e, ui) {
      window.location.href = BO_BASE + "/products/" + ui.item.id;
    }
  });
  $(".search_orders").autocomplete({
    minLength: 2,
    delay: 250,
    source: ajaxSource(BO_BASE + "/orders/autocomplete"),
    select: function (e, ui) {
      window.location.href = BO_BASE + "/orders/" + ui.item.id;
    }
  });
});
</script>

<script type="text/javascript">
        function setCookie(key, value) {
            var expires = new Date();
            expires.setTime(expires.getTime() + (1 * 24 * 60 * 60 * 1000));
            document.cookie = key + '=' + value + ';expires=' + expires.toUTCString();
        }

        function getCookie(key) {
            var keyValue = document.cookie.match('(^|;) ?' + key + '=([^;]*)(;|$)');
            return keyValue ? keyValue[2] : null;
        }
</script>

<% parent_layout "ecommerce/base" %>
