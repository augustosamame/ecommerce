<div class="page-header">
  <h1>Abandoned Carts</h1>
  <p class="text-muted">Active carts with at least one item, idle for at least <%= @min_hours %> hour<%= 's' unless @min_hours == 1 %>.</p>
</div>

<div class="panel panel-default">
  <div class="panel-body">
    <%= form_with url: backoffice_abandoned_carts_path, method: :get, local: true, class: "form-inline" do %>
      <div class="form-group" style="margin-right:10px;">
        <label style="margin-right:5px;">Min hours old</label>
        <%= number_field_tag :min_hours, @min_hours, min: 1, class: "form-control", style: "width:90px;" %>
      </div>
      <%= submit_tag "Apply", class: "btn btn-primary" %>
      <%= link_to "Reset", backoffice_abandoned_carts_path, class: "btn btn-default" %>
    <% end %>
  </div>
</div>

<div class="row">
  <% [
    ["Carts",              @total_carts],
    ["With user",          @carts_with_user],
    ["Guest / no user",    @carts_without_user],
    ["Total items",        @total_items],
    ["Estimated value",    number_to_currency(@total_value_cents.to_f / 100.0, unit: Ecommerce.default_currency&.upcase || 'PEN', format: '%n %u')]
  ].each do |label, value| %>
    <div class="col-md-2 col-sm-4 col-xs-6">
      <div class="panel panel-default">
        <div class="panel-body text-center">
          <div style="font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.5px;"><%= label %></div>
          <div style="font-size:22px;font-weight:600;margin-top:4px;">
            <%= value.is_a?(Numeric) ? number_with_delimiter(value) : value %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-bordered table-hover">
    <thead>
      <tr>
        <th>Cart</th>
        <th>User</th>
        <th>Contact</th>
        <th>Items</th>
        <th class="text-right">Qty</th>
        <th class="text-right">Est. value</th>
        <th>Cart created</th>
        <th>Last item added</th>
        <th>Age</th>
        <th>Email sent</th>
        <th>Opened</th>
        <th>Clicked</th>
      </tr>
    </thead>
    <tbody>
      <% if @carts.empty? %>
        <tr><td colspan="12" class="text-center text-muted">No abandoned carts match the current filter.</td></tr>
      <% else %>
        <% @carts.each do |cart| %>
          <%
            items        = cart.cart_items.to_a
            qty          = items.sum { |i| i.quantity.to_i }
            value_cents  = items.sum { |i|
              price = i.product&.discounted_price_cents.presence || i.product&.price_cents.to_i
              i.quantity.to_i * price.to_i
            }
            last_added   = items.map(&:updated_at).compact.max || cart.updated_at
            age_seconds  = Time.current - cart.created_at
            age_label    = age_seconds >= 1.day  ? "#{(age_seconds / 1.day).floor}d" :
                           age_seconds >= 1.hour ? "#{(age_seconds / 1.hour).floor}h" :
                                                   "#{(age_seconds / 1.minute).floor}m"
          %>
          <tr>
            <td>#<%= cart.id %></td>
            <td>
              <% if cart.user %>
                <%= link_to "#{cart.user.first_name} #{cart.user.last_name}".strip.presence || "User ##{cart.user.id}",
                            backoffice_user_path(cart.user) %>
              <% else %>
                <span class="text-muted">Guest</span>
              <% end %>
            </td>
            <td>
              <% if cart.user %>
                <div><%= cart.user.email %></div>
                <% if cart.user.respond_to?(:phone) && cart.user.phone.present? %>
                  <div class="text-muted"><%= cart.user.phone %></div>
                <% elsif cart.user.respond_to?(:username) && cart.user.username.present? %>
                  <div class="text-muted">+51<%= cart.user.username %></div>
                <% end %>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
            <td>
              <% if items.empty? %>
                <span class="text-muted">—</span>
              <% else %>
                <ul style="margin:0;padding-left:18px;">
                  <% items.each do |item| %>
                    <li>
                      <% if item.product %>
                        <%= link_to item.product.name, backoffice_product_path(item.product) %>
                      <% else %>
                        <span class="text-muted">(deleted product)</span>
                      <% end %>
                      &times; <%= item.quantity %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </td>
            <td class="text-right"><%= qty %></td>
            <td class="text-right">
              <%= number_to_currency(value_cents.to_f / 100.0,
                                     unit: Ecommerce.default_currency&.upcase || 'PEN',
                                     format: '%n %u') %>
            </td>
            <td><%= cart.created_at&.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= last_added&.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= age_label %></td>
            <%
              send_row = @email_send_by_cart_id[cart.id]
            %>
            <td>
              <% if send_row&.sent_at %>
                <%= send_row.sent_at.strftime("%Y-%m-%d %H:%M") %>
              <% elsif cart.abandoned_email_sent %>
                <span class="text-muted">sent (untracked)</span>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
            <td>
              <% if send_row&.first_opened_at %>
                <span class="label label-success">Yes</span>
                <div class="text-muted" style="font-size:11px;">
                  <%= send_row.first_opened_at.strftime("%Y-%m-%d %H:%M") %>
                  <% if send_row.opens_count.to_i > 1 %>
                    (<%= send_row.opens_count %>×)
                  <% end %>
                </div>
              <% elsif send_row %>
                <span class="text-muted">No</span>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
            <td>
              <% if send_row&.first_clicked_at %>
                <span class="label label-primary">Yes</span>
                <div class="text-muted" style="font-size:11px;">
                  <%= send_row.first_clicked_at.strftime("%Y-%m-%d %H:%M") %>
                  <% if send_row.clicks_count.to_i > 1 %>
                    (<%= send_row.clicks_count %>×)
                  <% end %>
                </div>
              <% elsif send_row %>
                <span class="text-muted">No</span>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>

<%= paginate @carts %>
