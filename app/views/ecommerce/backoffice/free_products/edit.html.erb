<div class="page-header">
  <h1>Free Product</h1>
  <p class="text-muted">
    When active on a platform, exactly one unit of the selected product is auto-added to every cart on that platform at S/ 0.01 / $ 0.01 and cannot be removed or its quantity changed. Web and App can be enabled independently.
  </p>
</div>

<%= simple_form_for @free_product, url: backoffice_free_product_path, method: :patch do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <div class="well">
      <%= f.input :web_active, as: :boolean, label: 'Active on Web' %>
      <%= f.input :app_active, as: :boolean, label: 'Active on App' %>
      <small class="text-muted">At least one of Web or App must be checked when a product is selected.</small>
    </div>

    <%= f.input :product_id,
        as: :select2,
        collection: Ecommerce::Product.active.order(:name),
        label_method: :name,
        label: 'Free product',
        include_blank: '— select a product —' %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, 'Save', class: 'btn btn-primary' %>
  </div>
<% end %>

<script>
  $(document).ready(function () {
    $('#free_product_product_id').select2({ width: '100%' });
  });
</script>
