<% if current_user.driver? && browser.device.mobile? %>
  <div class="page-header">
    <div class="btn-toolbar">
      <%= link_to backoffice_recent_orders_path, class: 'btn btn-default btn-sm' do %>
        <span class="glyphicon glyphicon-arrow-left"></span> Back
      <% end %>

      <!-- Direct upload buttons - no modal -->
      <button type="button" class="btn btn-success btn-sm" id="camera-btn">
        <span class="glyphicon glyphicon-camera"></span> Cámara
      </button>
      <button type="button" class="btn btn-info btn-sm" id="gallery-btn">
        <span class="glyphicon glyphicon-picture"></span> Galería
      </button>
    </div>
    <h1 style="font-size: 20px; margin-top: 10px;">Order #<%= @backoffice_order.id %></h1>
  </div>
<% else %>
  <div class="page-header">
    <div class="row">
      <div class="col-xs-12">
        <div class="btn-toolbar">
          <%= link_to current_user.driver? ? backoffice_recent_orders_path : backoffice_orders_path, class: 'btn btn-default btn-sm' do %>
            <span class="glyphicon glyphicon-list-alt"></span>
            <span>Back</span>
          <% end %>

          <!-- Direct upload buttons - no modal -->
          <button type="button" class="btn btn-success btn-sm" id="camera-btn">
            <span class="glyphicon glyphicon-camera"></span>
            <span>Cámara</span>
          </button>
          <button type="button" class="btn btn-info btn-sm" id="gallery-btn">
            <span class="glyphicon glyphicon-picture"></span>
            <span>Galería</span>
          </button>

          <% unless current_user.driver? %>
            <%= link_to edit_backoffice_order_path(@backoffice_order), class: 'btn btn-primary btn-sm' do %>
              <span class="glyphicon glyphicon-pencil"></span>
              Edit
            <% end %>

            <%= link_to backoffice_order_path(@backoffice_order), class: 'btn btn-danger btn-sm', style: 'margin-left: 10px;', method: :delete, data: { confirm: 'Are you sure?' } do %>
              <span class="glyphicon glyphicon-trash"></span>
              Delete
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <h1 style="font-size: 24px; margin-top: 10px;"><%= "Order ##{@backoffice_order.id}" %></h1>
  </div>
<% end %>

<% if current_user.driver? && browser.device.mobile? %>
  <!-- Mobile view -->
  <div class="panel panel-default">
    <div class="panel-body">
      <p><strong>Date / Time:</strong><br><%= friendly_formatted_date(@backoffice_order.created_at) %></p>
      <p><strong>User:</strong><br><%= @backoffice_order.user.name %></p>
      <p><strong>Order Total:</strong><br><%= number_to_currency(@backoffice_order.amount) %></p>
      <p><strong>Shipping Amount:</strong><br><%= number_to_currency(@backoffice_order.shipping_amount) %></p>
      <p><strong>Stage:</strong><br><%= @backoffice_order.friendly_stage %></p>
      <p><strong>Shipping address:</strong><br><%= @backoffice_order.friendly_shipping_address %></p>
      <p><strong>Payment status:</strong><br><span style="<%= @backoffice_order.unpaid? ? 'color: red; font-size: 16px;' : '' %>"><%= @backoffice_order.payment_status %></span></p>
      <p><strong>Delivery Instructions:</strong><br><%= @backoffice_order.delivery_comments.present? ? @backoffice_order.delivery_comments : 'None' %></p>
    </div>
  </div>
<% else %>
  <!-- Desktop view -->
  <dl class="dl-horizontal">

  <dt>Date / Time:</dt>
  <dd><%= friendly_formatted_date(@backoffice_order.created_at) %></dd>

  <dt>User:</dt>
  <dd><%= @backoffice_order.user.name %></dd>

  <dt>Order Total (w/ ship & disc):</dt>
  <dd><%= number_to_currency(@backoffice_order.amount) %></dd>

  <dt>Shipping Amount:</dt>
  <dd><%= number_to_currency(@backoffice_order.shipping_amount) %></dd>

  <dt>Coupon Discount Amount:</dt>
  <dd><%= number_to_currency(@backoffice_order.discount_amount) %></dd>

  <dt>Stage:</dt>
  <dd><%= @backoffice_order.friendly_stage %></dd>

  <dt>Shipping address:</dt>
  <dd><%= @backoffice_order.friendly_shipping_address %></dd>

  <dt>Billing address:</dt>
  <dd><%= @backoffice_order.friendly_billing_address %></dd>

  <dt>Efact Type:</dt>
  <dd><%= @backoffice_order.efact_type %></dd>

  <dt>Coupon:</dt>
  <dd><%= @backoffice_order.coupon.try(:coupon_code) %></dd>

  <dt>Delivery Special Instructions:</dt>
  <dd><%= @backoffice_order.delivery_comments %></dd>

  <dt>Payment status:</dt>
  <dd style= "<%= @backoffice_order.unpaid? ? 'color: red; font-size: 18px;' : '' %>"><%= @backoffice_order.payment_status %></dd>

  <dt>Payment Method:</dt>
  <dd style= <%= @backoffice_order.process_comments %></dd>

  <dt>Status:</dt>
  <dd><%= @backoffice_order.status %></dd>

  </dl>
<% end %>


<%= render 'order_details' %>

<h3 style='margin-top: 50px;'>Associated Payment Records</h3>
<%= render :partial => "ecommerce/backoffice/orders/payment_index", locals: {payments: @payments} %>

<h3 style='margin-top: 50px;'>Associated Order Adresses</h3>
<%= render "ecommerce/backoffice/addresses/index" %>

<%= render 'einvoice' %>

<!-- Proof of Delivery Images Gallery -->
<h3 style='margin-top: 30px; font-size: 20px;'>Imágenes de Entrega</h3>
<div class="row">
  <% @backoffice_order.proof_of_delivery_images.recent.each do |image| %>
    <div class="<%= (current_user.driver? && browser.device.mobile?) ? 'col-xs-12' : 'col-md-3 col-sm-4' %>" style="margin-bottom: 15px;">
      <div class="thumbnail">
        <%= image_tag image.proof_of_delivery.large.url, class: "img-responsive", style: "width: 100%; height: auto; max-width: 100%;" %>
        <div class="caption">
          <p style="margin-bottom: 5px;"><small>Subido por: <%= image.user.name %></small></p>
          <p style="margin-bottom: 10px;"><small><%= image.created_at.strftime("%d/%m/%Y %H:%M") %></small></p>
          <div class="text-center">
            <button onclick="downloadImage('<%= image.proof_of_delivery.url %>', 'entrega_orden_<%= @backoffice_order.id %>_<%= image.id %>.jpg')" class="btn btn-xs btn-primary">
              <span class="glyphicon glyphicon-download-alt"></span>
              <% unless current_user.driver? && browser.device.mobile? %><span>Descargar</span><% end %>
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  
  <% if @backoffice_order.proof_of_delivery_images.empty? %>
    <div class="col-md-12">
      <p class="text-muted">No hay imágenes de entrega para esta orden.</p>
    </div>
  <% end %>
</div>

<!-- Hidden forms for direct camera/gallery upload -->
<form id="camera-form" action="<%= backoffice_order_proof_of_delivery_images_path(@backoffice_order) %>" method="post" enctype="multipart/form-data" style="display: none;">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="file" name="proof_of_delivery_image[proof_of_delivery]" accept="image/*" capture="environment" id="camera-input">
</form>

<form id="gallery-form" action="<%= backoffice_order_proof_of_delivery_images_path(@backoffice_order) %>" method="post" enctype="multipart/form-data" style="display: none;">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="file" name="proof_of_delivery_image[proof_of_delivery]" accept="image/*" id="gallery-input">
</form>

<script>
// Force download of images from S3
function downloadImage(url, filename) {
  const link = document.createElement('a');
  link.href = url;
  link.download = filename;
  link.target = '_blank';

  fetch(url)
    .then(response => response.blob())
    .then(blob => {
      const blobUrl = window.URL.createObjectURL(blob);
      link.href = blobUrl;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      setTimeout(() => window.URL.revokeObjectURL(blobUrl), 100);
    })
    .catch(error => {
      console.error('Error downloading image:', error);
      window.open(url, '_blank');
    });
}

$(document).ready(function() {
  // Camera button - opens camera directly
  $('#camera-btn').on('click', function(e) {
    e.preventDefault();
    $('#camera-input').click();
  });

  // Gallery button - opens gallery/file picker
  $('#gallery-btn').on('click', function(e) {
    e.preventDefault();
    $('#gallery-input').click();
  });

  // Auto-submit when file is selected from camera
  $('#camera-input').on('change', function() {
    if (this.files && this.files[0]) {
      $('#camera-form').submit();
    }
  });

  // Auto-submit when file is selected from gallery
  $('#gallery-input').on('change', function() {
    if (this.files && this.files[0]) {
      $('#gallery-form').submit();
    }
  });
});
</script>

<!-- Discount Calculation Details -->
<% if @backoffice_order.discount_calculation.present? %>
  <h3 style='margin-top: 50px;'>Discount Calculation Details</h3>
  <div class="<%= (current_user.driver? && browser.device.mobile?) ? 'panel panel-default' : '' %>">
    <% if current_user.driver? && browser.device.mobile? %>
      <div class="panel-body">
        <pre style="font-size: 12px; white-space: pre-wrap;"><%= @backoffice_order.discount_calculation %></pre>
      </div>
    <% else %>
      <div class="well">
        <pre style="font-size: 13px; white-space: pre-wrap;"><%= @backoffice_order.discount_calculation %></pre>
      </div>
    <% end %>
  </div>
<% end %>
