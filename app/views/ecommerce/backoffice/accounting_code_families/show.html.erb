<div class="page-header">
  <%= link_to backoffice_accounting_code_families_path, class: 'btn btn-default' do %>
    <span class="glyphicon glyphicon-list-alt"></span>
    Back
  <% end %>
  <%= link_to edit_backoffice_accounting_code_family_path(@backoffice_accounting_code_family), class: 'btn btn-primary' do %>
    <span class="glyphicon glyphicon-pencil"></span>
    Edit
  <% end %>
  <h1>Show Accounting Code Family</h1>
</div>

<dl class="dl-horizontal">
  <dt>Accounting Code:</dt>
  <dd><%= @backoffice_accounting_code_family.accounting_code %></dd>
  <dt>Product Family:</dt>
  <dd><%= @backoffice_accounting_code_family.product_family %></dd>
</dl>
