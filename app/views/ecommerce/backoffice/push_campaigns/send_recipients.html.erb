<div class="page-header">
  <%= link_to backoffice_push_campaigns_path, class: 'btn btn-default' do %>
    <span class="glyphicon glyphicon-list-alt"></span>
    Back
  <% end %>
  <h1>Send Bulk Push Notification</h1>
</div>

<dl class="dl-horizontal">
  <dt>Name:</dt>
  <dd><%= @push_campaign.name %></dd>

  <dt>Coupon:</dt>
  <dd><%= @push_campaign.coupon.try(:coupon_code) %></dd>

  <dt>Title:</dt>
  <dd><%= @push_campaign.title %></dd>

  <dt>Body:</dt>
  <dd><%= @push_campaign.body %></dd>
</dl>

<div class="alert alert-info">
  Audience is restricted to users with the app installed (Expo push token registered).
  <strong>Total reachable users right now: <%= @total_app_users %></strong>.
  Filters below operate within this universe — users without the app are excluded automatically.
</div>

<div class= "col-lg-8">
  <div class="well" style="margin-top: 0px;">
    <h2><strong>Audience Selection</strong></h2>
    <div class= "row" style="margin-bottom: 30px; margin-left: 0px;">
      <button type="button" class="btn btn-info" id="select_all_app_users">Select all <%= @total_app_users %> app users</button>
    </div>
    <div class= "row" style="margin-bottom: 30px; margin-left: 0px;">
      <h3>Filter by Purchasers of Product (app users only)</h3>
      <span class="add-on">Choose Product:</span>
      <input name="" type="text" class="no-boarder search_purchaser_products" placeholder="start typing to search..." style="width:250px;">
    </div>
    <div class= "row" style="margin-bottom: 30px; margin-left: 0px;">
      <h3>Filter by Purchasing Activity (app users only)</h3>
      <span style="margin-right: 5px;">No Purchases in last</span>
      <input name="days_since_purchase" type="text" class="" style="width:50px;" id="days_since_purchase">
      <span style="margin-left: 5px;"> days</span>
    </div>
  </div>

  <div class="well" style="margin-top: 0px;">
    <%= simple_form_for([:backoffice, @push_campaign], url: backoffice_push_post_send_recipients_path(@push_campaign), method: :post) do |f| %>
      <%= f.error_notification %>

      <%= simple_fields_for :other do |o| %>

        <h2><strong>Audiences</strong></h2>
        <div class= "row" style="margin-bottom: 30px; margin-left: 0px;">
          <h3>Send to Predetermined Audience</h3>
          <span class="add-on">Choose Audience:</span>
        </div>

        <%= o.input :audience_id, as: :integer, input_html: {value: @push_campaign.audience_id} %>

  </div>

  <div class="well" style="margin-top: 0px;">
        <h3 id="recipientLabel">Total Number of Recipients: 0</h3>
        <div id="recipient_list_container" style="max-height: 400px; overflow-y: auto;">
          <p class="text-muted">No recipients selected yet. Use the buttons above to populate.</p>
        </div>
        <%= o.input :user_list, as: :hidden %>
        <%= o.input :coupon_id, as: :hidden, input_html: {value: @push_campaign.coupon.try(:id)} %>
      <% end %>

  </div>

  <div class="form-actions">
    <%= f.button :submit, 'Send Bulk Push', class: "btn btn-primary" %>
  </div>
  <% end %>
</div>

<script>

document.addEventListener('DOMContentLoaded', function(){

  products_tags = jQuery.parseJSON(<%= raw @products_array.to_json.inspect %>);

  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderRecipients(response) {
    if (!response) return;
    var ids = JSON.parse(response.data);
    var users = response.users || [];
    var total = response.total || 0;
    var previewLimit = response.preview_limit || users.length;

    $("#other_user_list").val(ids.join(','));
    $("#recipientLabel").text("Total Number of Recipients: " + total);

    if (users.length === 0) {
      $("#recipient_list_container").html("<p class='text-muted'>No recipients match this filter.</p>");
      return;
    }

    var rows = users.map(function(u) {
      return '<tr>' +
        '<td>' + u.id + '</td>' +
        '<td>' + escapeHtml(u.name) + '</td>' +
        '<td>' + escapeHtml(u.email) + '</td>' +
        '<td>' + escapeHtml(u.phone) + '</td>' +
      '</tr>';
    }).join('');

    var moreNote = total > users.length
      ? '<p class="text-muted" style="margin-top:10px;">Showing first ' + users.length + ' of ' + total + ' recipients (preview limit: ' + previewLimit + '). All ' + total + ' will be sent.</p>'
      : '';

    var table = '<table class="table table-striped table-condensed">' +
      '<thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Phone</th></tr></thead>' +
      '<tbody>' + rows + '</tbody>' +
    '</table>' + moreNote;

    $("#recipient_list_container").html(table);
  }

  function fetchRecipients(url) {
    $("#recipient_list_container").html("<p class='text-muted'>Loading…</p>");
    $.ajax({
      url: url,
      type: 'GET',
      dataType: "json",
      success: function(response) { renderRecipients(response); },
      error: function() {
        $("#recipient_list_container").html("<p class='text-danger'>Failed to load recipients.</p>");
      }
    });
  }

  $(".search_purchaser_products").autocomplete({
    autoFocus: false,
    minLength: 1,
    source: products_tags,
    select: function (e, ui) {
      $("#days_since_purchase").val("");
      fetchRecipients("/store/backoffice/push_get_purchasers?product_id=" + ui.item.id);
    },
  });

  $("#days_since_purchase").change(function() {
    $(".search_purchaser_products").val("");
    fetchRecipients("/store/backoffice/push_get_no_purchase_within_days?days=" + $(this).val());
  });

  $("#select_all_app_users").click(function(e) {
    e.preventDefault();
    $(".search_purchaser_products").val("");
    $("#days_since_purchase").val("");
    fetchRecipients("/store/backoffice/push_get_all_app_users");
  });

});
</script>
