<script type="application/ld+json">
<%= raw product_json_ld(@product).to_json %>
</script>
<script type="application/ld+json">
<%= raw breadcrumb_json_ld(@product).to_json %>
</script>

<div id="fb-root"></div>
<script>(function(d, s, id) {
  var js, fjs = d.getElementsByTagName(s)[0];
  if (d.getElementById(id)) return;
  js = d.createElement(s); js.id = id;
  js.src = 'https://connect.facebook.net/<%= @fb_compatible_locale_code %>/sdk.js#xfbml=1&version=v2.12&appId=<%= Ecommerce.fb_app_id %>&autoLogAppEvents=1';
  fjs.parentNode.insertBefore(js, fjs);
}(document, 'script', 'facebook-jssdk'));</script>

<main class="product-details-main" data-availability="<%= @product.in_stock? ? 'in_stock' : 'out_of_stock' %>">
  <section class="product-details">
    <div class="container-fluid">
      <!-- Breadcrumb navigation -->
      <nav aria-label="breadcrumb" style="margin-bottom: 15px;">
        <ol class="breadcrumb" style="background: transparent; padding: 0; margin: 0; font-size: 13px;">
          <li class="breadcrumb-item"><%= link_to "Home", main_app.root_path %></li>
          <li class="breadcrumb-item"><%= link_to t('.all_products', default: 'Products'), products_path %></li>
          <% first_category = @product.translated_category_list.first %>
          <% if first_category %>
            <% cat = Ecommerce::Category.find_by("lower(name) = ?", first_category.downcase) %>
            <% if cat %>
              <li class="breadcrumb-item"><%= link_to first_category, products_path(category_id: cat.id) %></li>
            <% end %>
          <% end %>
          <li class="breadcrumb-item active" aria-current="page"><%= @product.name %></li>
        </ol>
      </nav>
      <div class="row">
        <div class="col-md-5">
          <% gallery = ([{ type: 'image', url: @product.image.url, thumb: @product.image.try(:thumb_100).try(:url) || @product.image.url }] +
                       @product.media.order(:position, :id).map do |m|
                         next nil if m.file.blank?
                         if m.image?
                           { type: 'image', url: m.file.url, thumb: m.file.try(:thumb_100).try(:url) || m.file.url }
                         else
                           { type: 'video', url: m.file.url, thumb: nil }
                         end
                       end.compact).reject { |g| g[:url].blank? } %>

          <% if gallery.size <= 1 %>
            <%= link_to @product.image.url do %>
              <%= image_tag @product.image.url, class: "img-responsive desktop-500", alt: @product.name %>
            <% end %>
          <% else %>
            <div class="product-gallery" id="product-gallery">
              <div class="product-gallery-main"
                   style="position: relative; width: 100%; aspect-ratio: 1 / 1; background: #fff; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                <%= image_tag gallery.first[:url],
                              class: "product-gallery-main-img",
                              id: "product-gallery-main-img",
                              alt: @product.name,
                              style: "max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain;" %>
                <video src="" controls
                       style="display:none; max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; background: #000;"
                       id="product-gallery-main-video"></video>
              </div>
              <div class="product-gallery-thumbs" style="display:flex; gap:8px; margin-top:8px; flex-wrap:wrap;">
                <% gallery.each_with_index do |item, idx| %>
                  <a href="#" class="product-gallery-thumb <%= 'active' if idx == 0 %>"
                     data-type="<%= item[:type] %>"
                     data-url="<%= item[:url] %>"
                     style="border:<%= idx == 0 ? '2px solid #c33' : '1px solid #ddd' %>; padding:2px; display:inline-block;">
                    <% if item[:type] == 'image' %>
                      <%= image_tag item[:thumb] || item[:url], style: "width:60px; height:60px; object-fit:cover;", alt: "" %>
                    <% else %>
                      <span style="display:inline-block; width:60px; height:60px; background:#000; color:#fff; text-align:center; line-height:60px;">▶</span>
                    <% end %>
                  </a>
                <% end %>
              </div>
            </div>

            <script>
              (function() {
                var $main = document.getElementById('product-gallery-main-img');
                var $video = document.getElementById('product-gallery-main-video');
                var thumbs = document.querySelectorAll('.product-gallery-thumb');
                thumbs.forEach(function(t) {
                  t.addEventListener('click', function(e) {
                    e.preventDefault();
                    thumbs.forEach(function(x) { x.style.borderColor = '#ddd'; x.style.borderWidth = '1px'; });
                    t.style.borderColor = '#c33'; t.style.borderWidth = '2px';
                    var type = t.getAttribute('data-type');
                    var url = t.getAttribute('data-url');
                    if (type === 'video') {
                      $main.style.display = 'none';
                      $video.style.display = 'block';
                      $video.src = url;
                      $video.play();
                    } else {
                      $video.pause();
                      $video.style.display = 'none';
                      $video.src = '';
                      $main.style.display = '';
                      $main.src = url;
                    }
                  });
                });
              })();
            </script>
          <% end %>
        </div>
        <div class="col-md-7">
          <h3><%= @product.name %></h3>
          <% if @product.price == @product.discounted_price %>
            <div class="price d-flex hidden-xs">
              <p class="product-info-price single-30"><%= product_session_price(@product, "current_price") %></p>
            </div>
          <% else %>
            <div class="price d-flex hidden-xs">
              <p class="product-info-price-regular single-30"><%= product_session_price(@product, "price") %></p>
              <p class="product-info-price-discounted single-30"><%= product_session_price(@product, "current_price") %></p>
            </div>
          <% end %>
          <!-- Product facts (hidden, for LLM/SEO use) -->
          <div class="product-facts" style="display: none;">
            <% if @product.brand&.name.present? %>
              <p><strong><%= t('.brand', default: 'Brand') %>:</strong> <%= @product.brand.name %></p>
            <% end %>
            <p><strong>SKU:</strong> <%= @product.id %></p>
            <p><strong><%= t('.availability', default: 'Availability') %>:</strong>
              <% if @product.in_stock? %>
                <span><%= t('.in_stock', default: 'In Stock') %></span>
              <% else %>
                <span><%= t('.out_of_stock') %></span>
              <% end %>
            </p>
            <% if @product.weight.present? && @product.weight > 0 %>
              <p><strong><%= t('.weight', default: 'Weight') %>:</strong> <%= friendly_cart_weight(@product.weight) %></p>
            <% end %>
          </div>
          <p>
            <%= @product.description.gsub("**","<br>").html_safe if @product.description %>
          </p>
          <p class="hidden-xs">
            <%= t('.categories') %>
            <span>
              <% @product.translated_category_list.each do |cl| %>
              <span>
                <%= link_to cl, products_path(category_id: Ecommerce::Category.find_by("lower(name) = ?", cl.downcase).try(:id)), style: "" %>
              </span>
              <% end %>
            </span>
          </p>
          <% if @product.price == @product.discounted_price %>
            <div class="visible-xs">
              <div class="price d-flex">
                <p class="product-info-price"><%= product_session_price(@product, "current_price") %></p>
              </div>
            </div>
          <% else %>
            <div class="visible-xs">
              <div class="price d-flex">
                <div class="price-inner-wrapper">
                  <p class="product-info-price-regular"><%= product_session_price(@product, "price") %></p>
                  <p class="product-info-price-discounted"><%= product_session_price(@product, "current_price") %></p>
                </div>
              </div>
            </div>
          <% end %>
          <div>
            <p class="out_of_stock" aria-hidden="true"><span class="" id="out_of_stock_text"></span></p>
          </div>
          <div class="add-to-cart-btn-group max-360">
            <% if @product.in_stock? %>
              <%= simple_form_for @cart_item, remote: true, html: { class: "cart-form" } do |f| %>
                <div class="add-to-cart-btn-container">

                  <div class="yith-wcwl-add-to-wishlist yith-wcwl-add-to-wishlist_index devtech_minus_class container-minus-plus" id="devtech_minus">
                    <a href="#" class="add_to_wishlist devtech_minus_a_class no-click-styles" %>-</a>
                  </div>
                  <div class="quantity container-qty" id="devtech_quantity">
                    <%= f.input :quantity, label: false, input_html: { class: 'input-text qty text no-spinners', id: "devtech_quantity_field", value: "1", size: "4", step: "1", min: "1" } %>
                  </div>

                  <%= button_tag type: 'submit', class: "btn btn-default index_single_add_to_cart_button button container-cart-button single_add_to_cart_button" do %>
                    <%= fa_icon('shopping-cart', style: 'color: white;') %>
                    <%= t('.add_to_cart') %>
                  <% end %>

                  <div class="yith-wcwl-add-to-wishlist yith-wcwl-add-to-wishlist_index devtech_plus_class container-minus-plus" id="devtech_plus">
                    <a href="#" class="add_to_wishlist devtech_plus_a_class no-click-styles" >+</a>
                  </div>


                </div>

                  <%= f.hidden_field :product_id, value: @product.id, id: "product_product_id_#{@product.id}" %>
                <% end %>


            <% else %>
              <%= simple_form_for Ecommerce::StockAlert.new, remote: true, html: { class: "stock_alert", id: "stock_alert_#{@product.id}" } do |f| %>
                <%= f.button :submit, t('.alert_me'), class: "index_single_stock_alert_button button" %>
                <%= f.hidden_field :product_id, value: @product.id, id: "product_product_id_#{@product.id}" %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>



  <section class="related-products">
    <h3 style="text-transform: uppercase;"><%= t('.related_products') %></h3>
    <div class="container">
      <div class="row related-product-slider">

        <%= render partial: "ecommerce/#{Ecommerce.ecommerce_layout}/product/product", collection: @related_products, as: :item %>

      </div>
    </div>
  </section>
</main>

<script>
  var outOfStockMsg = "<%= j t('.no_more_stock_available') %>";
  $("#devtech_plus").click(function(e) {
    if ($("#devtech_quantity_field").val() < <%= @product.total_quantity %>) {
      $("#devtech_quantity_field").val(parseInt($("#devtech_quantity_field").val()) + 1);
    } else {
      $("#out_of_stock_text").text(outOfStockMsg);
      $(".out_of_stock").show();
      console.log("out of stock");
    }
    e.preventDefault();
  });
  $("#devtech_minus").click(function(e) {
    if (parseInt($("#devtech_quantity_field").val()) > 1) {
      $("#devtech_quantity_field").val(parseInt($("#devtech_quantity_field").val()) - 1);
    }
    $(".out_of_stock").hide();
    console.log("in stock");
    e.preventDefault();
  });

</script>
